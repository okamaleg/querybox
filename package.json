{
  "name": "querybox",
  "version": "0.1.0",
  "description": "Chat with your database using natural language",
  "author": "okamaleg",
  "private": true,
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite",
    "dev:electron": "concurrently -k \"npm run dev:server\" \"npm run dev:client\" \"wait-on http://localhost:3099/api/settings && wait-on http://localhost:5173 && tsc -p electron/tsconfig.json && electron .\"",
    "build": "tsc -p server/tsconfig.json && vite build",
    "build:electron": "npm run build && tsc -p electron/tsconfig.json && electron-builder"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@base-ui/react": "^1.3.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/static": "^9.0.0",
    "better-sqlite3": "^12.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fastify": "^5.8.0",
    "lucide-react": "^0.577.0",
    "mongodb": "^7.1.0",
    "mysql2": "^3.19.0",
    "pg": "^8.20.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0",
    "tailwind-merge": "^3.0.0",
    "tw-animate-css": "^1.4.0",
    "uuid": "^11.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22",
    "@types/pg": "^8.18.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.5.0",
    "concurrently": "^9.0.0",
    "electron": "^34.0.0",
    "electron-builder": "^26.0.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^6.3.0",
    "wait-on": "^9.0.0"
  }
}
